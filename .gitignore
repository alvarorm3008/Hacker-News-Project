# Root monorepo
.DS_Store
*.log

# Frontend (Vite / React)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Backend (Django)
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/venv/
backend/.venv/
backend/env/
backend/db.sqlite3
backend/media/*
!backend/media/.gitkeep
backend/staticfiles/*
!backend/staticfiles/.gitkeep

# Secrets / local env
.env
.env.*
!.env.example

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
